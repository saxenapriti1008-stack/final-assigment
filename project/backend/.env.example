PORT=3000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# PostgreSQL (docker-compose sets this automatically)
# Use 5433 if another Postgres already uses 5432 on your machine
DATABASE_URL=postgresql://gymuser:gympass@localhost:5433/gymreviews

# Firebase Admin — pick one (never commit real values):
# A) JSON file next to backend (recommended for local dev):
GOOGLE_APPLICATION_CREDENTIALS=./firebase/firebase-service-account.local.json
# B) Single-line JSON:
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Session cookie (use true in production behind HTTPS)
COOKIE_SECURE=false
SESSION_COOKIE_NAME=__session

# Set to true in tests to skip Firebase (uses test user)
TEST_MODE=false
